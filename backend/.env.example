# World Pieces — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Redis ─────────────────────────────────────────────────────────────────────
redis_password=YOUR_REDIS_PASSWORD_HERE

# ── GitHub OAuth App ──────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Homepage URL:      https://your-domain.com
# Callback URL:      https://your-domain.com/auth/callback
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=YOUR_RANDOM_64_CHAR_HEX_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── GitHub Sponsors GraphQL API ───────────────────────────────────────────────
# Personal Access Token with read:org and read:user scopes
# Create at: https://github.com/settings/tokens
GITHUB_SPONSORS_TOKEN=YOUR_GITHUB_PAT_HERE

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=World Pieces
BACKEND_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com
ALLOWED_ORIGINS=https://your-domain.com,http://localhost:8100

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
